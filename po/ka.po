msgstr ""
"iTunesDB ('%s'): mhsd ფრაგმენტის თავსართის სიგრძე მოსალოდნელზე მცირეა "
"(%d<32). მუშაობა შეწყდება."

#: ../src/itdb_itunesdb.c:1839
#, c-format
msgid "iTunesDB '%s' corrupt: mhsd expected at %ld."
msgstr "iTunesDB '%s' დაზიანებულიაt: მოველოდი mhsd-ს მისამართზე %ld."

#: ../src/itdb_itunesdb.c:1944
#, c-format
msgid "Number of MHODs in mhip at %ld inconsistent in file '%s'."
msgstr "MHOD-ების რაოდენობა mhip-ში მისმართზე %ld არამდგრადია ფაილში '%s'."

#: ../src/itdb_itunesdb.c:2121
#, c-format
