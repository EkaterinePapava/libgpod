#, c-format
msgid "Not a iTunesDB: '%s' (missing mhdb header)."
msgstr "არ არის iTunesDB: '%s' (აკლია mhdb თავსართები)."

#: ../src/itdb_itunesdb.c:1818
#, c-format
msgid ""
"iTunesDB ('%s'): header length of mhsd hunk smaller than expected (%d<32). "
